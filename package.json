{
  "name": "@theihtisham/ai-release-notes",
  "version": "1.0.0",
  "description": "Auto-generate beautiful release notes from commits, PRs, and diffs using AI",
  "main": "index.js",
  "scripts": {
    "build": "ncc build index.js -o dist --source-map",
    "test": "jest --coverage",
    "lint": "eslint src/",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
