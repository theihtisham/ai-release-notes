    "openai": "^4.67.0",
    "minimatch": "^9.0.4",
    "twitter-api-v2": "^1.16.0",
    "node-fetch": "^3.3.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0"
  },
  "keywords": [
    "github-action",
    "release-notes",
    "ai",
    "changelog",
